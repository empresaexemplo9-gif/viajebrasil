# ─────────────────────────────────────────────────────────────
# DRAP Business — variáveis de ambiente
# Copie para .env e preencha. No deploy (Vercel), defina em
# Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Banco de dados (PostgreSQL). No Vercel Postgres, use a connection string
# "pooled" para a app e a "direct" (non-pooling) para migrations.
DATABASE_URL="postgresql://usuario:senha@host:5432/drapbusiness?sslmode=require"
# Opcional: conexão direta p/ prisma migrate/db push (Vercel Postgres fornece).
DIRECT_URL=""

# NextAuth (obrigatório). Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# JWT interno das APIs (separado do NextAuth). openssl rand -base64 32
JWT_SECRET=""

# Admin da plataforma: e-mails (separados por vírgula) com acesso ao painel /admin
# para edições e reparos em TODA a plataforma.
ADMIN_EMAILS=""

# Cookie de sessão do MVP legado (demo em memória). openssl rand -base64 32
AUTH_SECRET=""

# OAuth de login
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
# Instagram (Meta for Developers) — quando disponível
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""

# IA (Anthropic) — classificação de currículos, score de perfil, conteúdo
ANTHROPIC_API_KEY=""

# E-mail transacional — recuperação de senha, notificações.
# Escolha UM transporte. Prioridade: SMTP > Resend > (sem envio, só log).
#
# Opção A — SMTP (sem depender de Resend; funciona com Gmail, Outlook, domínio próprio):
SMTP_HOST=""              # ex.: smtp.gmail.com
SMTP_PORT="587"           # 587 (TLS) ou 465 (SSL)
SMTP_USER=""              # login do SMTP
SMTP_PASS=""              # senha (no Gmail, use uma "Senha de app")
SMTP_SECURE=""            # "true" p/ porta 465; deixe vazio p/ 587
#
# Opção B — Resend (API HTTP):
RESEND_API_KEY=""
#
# Remetente (vale p/ qualquer transporte):
EMAIL_FROM="DRAP Business <onboarding@resend.dev>"

# Upload de imagens (Vercel Blob). Ative "Blob" em Storage na Vercel → a
# variável é injetada automaticamente. Sem ela, o upload cai no modo "colar URL".
BLOB_READ_WRITE_TOKEN=""

# Gateway de pagamento (assinaturas Prime) — Stripe. Opcional: sem isto, assinar
# apenas troca o plano (modo demonstração). Ver STRIPE.md.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# IDs de Price (recorrentes/mensais) criados no Stripe, um por plano Prime:
STRIPE_PRICE_BASICO=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ELITE=""

# Gateway de pagamento (assinaturas Prime) — Asaas. Quando ASAAS_API_KEY está
# definido, a assinatura de planos pagos vai para o checkout do Asaas (link de
# pagamento recorrente mensal). Tem prioridade sobre o Stripe.
ASAAS_API_KEY=""
# Ambiente: "producao" (padrão) ou "sandbox".
ASAAS_AMBIENTE="producao"
# Token que valida os webhooks (header asaas-access-token). Configure o mesmo
# valor no painel do Asaas, na URL: https://SEU_DOMINIO/api/asaas/webhook
ASAAS_WEBHOOK_TOKEN=""

# Armazenamento de mídia/documentos (AWS S3)
AWS_REGION="sa-east-1"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
