// DRAP Business — schema multi-tenant (PostgreSQL via Prisma).
//
// Estratégia: schema compartilhado com coluna `tenantId` em todas as tabelas
// de domínio. O isolamento é reforçado no banco com Row Level Security (RLS) —
// ver `prisma/rls.sql`. A aplicação injeta o tenant da sessão em cada transação
// (ver src/lib/server/prisma.ts → withTenant).
//
// IDs são UUID (gen_random_uuid via pgcrypto) para casarem com os casts ::uuid
// das políticas de RLS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Enums ─────────────────────────

enum Plano {
  free
  prime_basico
  prime_pro
  prime_elite
}

enum StatusAssinatura {
  trial
  ativa
  inadimplente
  cancelada
}

enum TipoPerfilUsuario {
  pessoa_fisica
  empresa
  autonomo
}

enum StatusUsuario {
  ativo
  suspenso
  pendente
}

enum PapelUsuario {
  super_admin
  admin
  manager
  recruiter
  seller
  candidate
  viewer
}

enum TipoProfile {
  candidato
  empresa_contratante
  vendedor
  comprador
}

enum NivelVaga {
  estagio
  junior
  pleno
  senior
  especialista
}

enum TipoContrato {
  CLT
  PJ
  FREELA
  TEMPORARIO
}

enum StatusVaga {
  aberta
  pausada
  fechada
}

enum StatusCandidatura {
  recebido
  em_analise
  aprovado
  recusado
}

enum StatusProduto {
  ativo
  inativo
  esgotado
}

enum TipoItem {
  produto
  servico
}

enum TipoCompromisso {
  reuniao
  negociacao
  apresentacao
  entrevista
}

enum StatusParticipacao {
  convidado
  aceito
  recusado
}

enum TipoMensagem {
  texto
  convite
}

enum EtapaLead {
  novo
  contato
  proposta
  ganho
  perdido
}

enum TipoAnalise {
  curriculo
  produto
  perfil
}

enum AcaoConvite {
  pendente
  aceito
  expirado
}

// ───────────────────────── Tenant ─────────────────────────

model Tenant {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome              String
  slug              String           @unique
  plano             Plano            @default(free)
  statusAssinatura  StatusAssinatura @default(trial)
  configuracoes     Json             @default("{}")
  logoUrl           String?
  dominioCustomizado String?         @unique
  stripeCustomerId  String?          @unique
  criadoEm          DateTime         @default(now())
  atualizadoEm      DateTime         @updatedAt

  users         User[]
  profiles      Profile[]
  jobs          Job[]
  applications  Application[]
  products      Product[]
  subscriptions Subscription[]
  auditLogs     AuditLog[]
  notifications Notification[]
  aiAnalyses    AiAnalysis[]
  convites      Convite[]
  leads         Lead[]

  @@index([slug])
  @@map("tenants")
}

// ───────────────────────── User ─────────────────────────

model User {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String            @db.Uuid
  nome         String
  email        String
  senhaHash    String?
  tipoPerfil   TipoPerfilUsuario @default(pessoa_fisica)
  papel        PapelUsuario      @default(viewer)
  avatarUrl    String?
  scoreIa      Int               @default(0)
  status       StatusUsuario     @default(pendente)
  emailVerificadoEm DateTime?
  tentativasLogin   Int          @default(0)
  bloqueadoAte      DateTime?
  ultimoAcesso DateTime?
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile      Profile?
  accounts     Account[]
  applications Application[]      @relation("CandidatoApplications")
  products     Product[]         @relation("VendedorProducts")
  jobs         Job[]             @relation("EmpresaJobs")
  auditLogs    AuditLog[]
  notifications Notification[]
  otpCodes     OtpCode[]
  reunioesOrganizadas Reuniao[]    @relation("OrganizadorReunioes")
  participacoes Participante[]
  conversas     ConversaParticipante[]
  mensagensChat MensagemChat[]
  posts         Post[]

  // E-mail único por tenant (mesmo e-mail pode existir em tenants distintos).
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// Conta OAuth vinculada (Google, LinkedIn, ...). Compatível com NextAuth.
model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  provider          String
  providerAccountId String
  type              String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// ───────────────────────── Profile ─────────────────────────

model Profile {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String      @db.Uuid
  userId          String      @unique @db.Uuid
  tipo            TipoProfile
  areaAtuacao     String?
  regiao          String?
  bio             String?
  bannerUrl       String?
  /// Marca/empresa que o perfil representa (opcional).
  representa      String?
  portfolio       Json        @default("[]")
  redesSociais    Json        @default("{}")
  visibilidadePublica Boolean @default(true)
  criadoEm        DateTime    @default(now())
  atualizadoEm    DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([visibilidadePublica])
  @@map("profiles")
}

// ───────────────────────── Job ─────────────────────────

model Job {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String       @db.Uuid
  empresaId   String       @db.Uuid
  titulo      String
  descricao   String
  requisitos  String?
  area        String?
  habilidades String[]     @default([])
  nivel       NivelVaga    @default(pleno)
  tipoContrato TipoContrato @default(CLT)
  regiao      String?
  status      StatusVaga   @default(aberta)
  planoNaPublicacao Plano  @default(free)
  expiraEm    DateTime?
  criadoEm    DateTime     @default(now())
  atualizadoEm DateTime    @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  empresa      User          @relation("EmpresaJobs", fields: [empresaId], references: [id])
  applications Application[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("jobs")
}

// ───────────────────────── Application ─────────────────────────

model Application {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String            @db.Uuid
  jobId         String            @db.Uuid
  candidateId   String            @db.Uuid
  curriculoUrl  String?
  scoreIa       Int?
  classificacaoIa Json?
  status        StatusCandidatura @default(recebido)
  criadoEm      DateTime          @default(now())
  atualizadoEm  DateTime          @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job       Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate User   @relation("CandidatoApplications", fields: [candidateId], references: [id])

  @@unique([jobId, candidateId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("applications")
}

// ───────────────────────── Product ─────────────────────────

model Product {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String        @db.Uuid
  sellerId    String        @db.Uuid
  nome        String
  descricao   String
  tipo        TipoItem      @default(produto)
  categoria   String?
  preco       Decimal?      @db.Decimal(12, 2)
  regiaoAtendimento String?
  imagens     Json          @default("[]")
  status      StatusProduto @default(ativo)
  planoNoCadastro Plano     @default(free)
  scoreRelevancia Int       @default(0)
  criadoEm    DateTime      @default(now())
  atualizadoEm DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  seller User   @relation("VendedorProducts", fields: [sellerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("products")
}

// ───────────────────────── Subscription ─────────────────────────

model Subscription {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String           @db.Uuid
  plano           Plano
  status          StatusAssinatura @default(trial)
  inicioEm        DateTime         @default(now())
  renovaEm        DateTime?
  gateway         String?
  paymentIdExterno String?
  faturas         Json             @default("[]")
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("subscriptions")
}

// ───────────────────────── AuditLog ─────────────────────────

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  userId       String?  @db.Uuid
  acao         String
  tabelaAfetada String?
  dadosAnteriores Json?
  dadosNovos   Json?
  ip           String?
  userAgent    String?
  timestamp    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, timestamp])
  @@map("audit_logs")
}

// ───────────────────────── Notification ─────────────────────────

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  tipo      String
  conteudo  String
  lido      Boolean  @default(false)
  criadoEm  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("notifications")
}

// ───────────────────────── AiAnalysis ─────────────────────────

model AiAnalysis {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String      @db.Uuid
  tipo         TipoAnalise
  referenciaId String      @db.Uuid
  score        Int
  resumo       String?
  detalhes     Json        @default("{}")
  modelo       String?
  criadoEm     DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, tipo, referenciaId])
  @@map("ai_analysis")
}

// ───────────────────────── Convite (entrar em tenant existente) ─────────────────────────

model Convite {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String      @db.Uuid
  email     String
  papel     PapelUsuario @default(viewer)
  token     String      @unique
  status    AcaoConvite @default(pendente)
  expiraEm  DateTime
  criadoEm  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("convites")
}

// ───────────────────────── OTP (login por código) ─────────────────────────

model OtpCode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  codigoHash String
  expiraEm  DateTime
  consumido Boolean  @default(false)
  criadoEm  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("otp_codes")
}

// ───────────────────────── Agenda (compromissos + call) ─────────────────────────

model Reuniao {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizadorId String          @db.Uuid
  organizadorTenantId String?   @db.Uuid
  titulo        String
  tipo          TipoCompromisso @default(reuniao)
  descricao     String?
  inicioEm      DateTime
  duracaoMin    Int             @default(30)
  /// Nome único da sala de call (Jitsi). Não-adivinhável.
  sala          String          @unique
  cancelada     Boolean         @default(false)
  criadoEm      DateTime        @default(now())

  organizador   User           @relation("OrganizadorReunioes", fields: [organizadorId], references: [id])
  participantes Participante[]

  @@index([organizadorId])
  @@map("reunioes")
}

model Participante {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reuniaoId String             @db.Uuid
  userId    String?            @db.Uuid
  email     String
  status    StatusParticipacao @default(convidado)
  organizador Boolean          @default(false)
  criadoEm  DateTime           @default(now())

  reuniao Reuniao @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([reuniaoId, email])
  @@index([userId])
  @@index([reuniaoId])
  @@map("participantes")
}

// ───────────────────────── Chat ─────────────────────────

model Conversa {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ultimaMsgEm DateTime @default(now())
  criadoEm   DateTime @default(now())

  participantes ConversaParticipante[]
  mensagens     MensagemChat[]

  @@map("conversas")
}

model ConversaParticipante {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversaId String   @db.Uuid
  userId     String   @db.Uuid
  criadoEm   DateTime @default(now())

  conversa Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversaId, userId])
  @@index([userId])
  @@map("conversa_participantes")
}

model MensagemChat {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversaId String       @db.Uuid
  autorId    String       @db.Uuid
  tipo       TipoMensagem @default(texto)
  texto      String
  /// Quando tipo=convite, referencia a reunião compartilhada.
  reuniaoId  String?      @db.Uuid
  criadoEm   DateTime     @default(now())

  conversa Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  autor    User     @relation(fields: [autorId], references: [id], onDelete: Cascade)

  @@index([conversaId])
  @@map("mensagens_chat")
}

// ───────────────────────── CRM (leads) ─────────────────────────

model Lead {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  responsavelId String?  @db.Uuid
  nome         String
  email        String?
  telefone     String?
  origem       String?
  valor        Decimal?  @db.Decimal(12, 2)
  etapa        EtapaLead @default(novo)
  notas        String?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, etapa])
  @@map("leads")
}

// ───────────────────────── Feed (publicações) ─────────────────────────

model Post {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  autorId   String   @db.Uuid
  tenantId  String?  @db.Uuid
  texto     String
  imagemUrl String?
  criadoEm  DateTime @default(now())

  autor User @relation(fields: [autorId], references: [id], onDelete: Cascade)

  @@index([autorId])
  @@index([criadoEm])
  @@map("posts")
}
